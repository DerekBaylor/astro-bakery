---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Derek’s Cakes – Home">

	<!-- Hero -->
	<section class="hero">
		<div class="hero-content">
			<h1>Welcome to Derek’s Cakes</h1>
			<p>
				Where every slice is a celebration. Handcrafted cakes made fresh daily
				with premium ingredients and a whole lot of love.
			</p>

			<div class="hero-actions">
				<a href="/menu" class="btn primary">View Menu</a>
				<a href="/contact" class="btn secondary">Order Now</a>
			</div>
		</div>
	</section>

	<!-- Why Choose Us -->
	<section class="features">
		<div class="section-header">
			<h2>Why Choose Derek’s Cakes?</h2>
		</div>

		<div class="feature-grid">
			<div class="feature-card">
				<span class="icon">🎂</span>
				<h3>Fresh Daily</h3>
				<p>All our cakes are baked fresh every morning using the finest ingredients.</p>
			</div>

			<div class="feature-card">
				<span class="icon">👨‍🍳</span>
				<h3>Expert Bakers</h3>
				<p>Over 50 years of combined baking experience in every creation.</p>
			</div>

			<div class="feature-card">
				<span class="icon">🎨</span>
				<h3>Custom Orders</h3>
				<p>Personalized cakes for birthdays, weddings, and special occasions.</p>
			</div>
		</div>
	</section>

	<!-- Featured -->
	<section class="featured">
		<div class="featured-content">
			<h2>Featured This Week</h2>
			<p>Chocolate Raspberry Dream Cake</p>
			<a href="/menu" class="btn primary">See Full Menu</a>
		</div>
	</section>

</Layout>

<style>
	:root {
		--bg-light: #fff7ed;
		--bg-accent: #fde68a;
		--text-dark: #3f2a1d;
		--accent: #b45309;
		--accent-hover: #92400e;
		--card-bg: #ffffff;
		--border: #e7d3b3;
	}

	/* ---------- HERO ---------- */

	.hero {
		background: linear-gradient(135deg, #fff7ed, #fde68a);
		padding: clamp(4rem, 10vw, 6rem) 1.25rem;
	}

	.hero-content {
		max-width: 900px;
		margin: 0 auto;
		text-align: center;
	}

	.hero h1 {
		font-size: clamp(2.5rem, 6vw, 3.5rem);
		color: var(--text-dark);
		margin-bottom: 1.25rem;
	}

	.hero p {
		font-size: 1.2rem;
		max-width: 600px;
		margin: 0 auto 2.5rem;
		color: #5a3c28;
		line-height: 1.6;
	}

	.hero-actions {
		display: flex;
		justify-content: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	/* ---------- BUTTONS ---------- */

	.btn {
		padding: 0.85rem 1.75rem;
		border-radius: 0.5rem;
		font-weight: 600;
		text-decoration: none;
		transition: background 0.2s ease, color 0.2s ease;
	}

	.btn.primary {
		background: var(--accent);
		color: white;
	}

	.btn.primary:hover {
		background: var(--accent-hover);
	}

	.btn.secondary {
		border: 2px solid var(--accent);
		color: var(--accent);
		background: transparent;
	}

	.btn.secondary:hover {
		background: var(--accent);
		color: white;
	}

	/* ---------- FEATURES ---------- */

	.features {
		padding: 5rem 1.25rem;
		background: var(--bg-light);
	}

	.section-header {
		text-align: center;
		margin-bottom: 3rem;
	}

	.section-header h2 {
		font-size: 2.25rem;
		color: var(--text-dark);
	}

	.feature-grid {
		max-width: 1100px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 2rem;
	}

	.feature-card {
		background: var(--card-bg);
		border-radius: 0.75rem;
		padding: 2rem;
		text-align: center;
		box-shadow: 0 10px 25px rgba(0,0,0,0.08);
	}

	.feature-card .icon {
		font-size: 3rem;
		display: block;
		margin-bottom: 1rem;
	}

	.feature-card h3 {
		margin-bottom: 0.75rem;
		color: var(--accent);
	}

	.feature-card p {
		color: #5a3c28;
		line-height: 1.5;
	}

	/* ---------- FEATURED ---------- */

	.featured {
		background: #fde68a;
		padding: 4.5rem 1.25rem;
		text-align: center;
	}

	.featured-content {
		max-width: 700px;
		margin: 0 auto;
	}

	.featured h2 {
		font-size: 2.25rem;
		color: var(--text-dark);
		margin-bottom: 0.75rem;
	}

	.featured p {
		font-size: 1.25rem;
		color: #5a3c28;
		margin-bottom: 2rem;
	}
</style>
