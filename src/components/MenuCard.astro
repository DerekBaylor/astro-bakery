---
interface Props {
    title: string;
    description: string;
    price: string;
}

const { title, description, price } = Astro.props;
---

<div class="menu-card">
    <h3>{title}</h3>
    <p>{description}</p>
    <span>{price}</span>
</div>

<style>
    .menu-card {
        background: white;
        padding: 2rem;
        border-radius: 0.75rem;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        display: flex;
        flex-direction: column;
    }

    .menu-card h3 {
        color: #b45309;
        margin-bottom: 0.5rem;
    }

    .menu-card p {
        color: #5a3c28;
        line-height: 1.5;
        margin-bottom: 1.25rem;
        flex-grow: 1;
    }

    .menu-card span {
        font-weight: 600;
        color: #3f2a1d;
    }
</style>
